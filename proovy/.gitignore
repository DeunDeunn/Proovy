### Gradle ###
.gradle/
build/
out/

### Java ###
*.class
hs_err_pid*
replay_pid*

# Package Files
*.jar
*.war
!gradle/wrapper/gradle-wrapper.jar

# Backend secret configs
src/main/resources/application-local.yaml
src/main/resources/application-prod.yaml
src/test/resources/application.yaml
