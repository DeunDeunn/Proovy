# 이 파일을 복사해서 .env.local로 만들어 쓰세요 (.env.local은 gitignore 대상)
#   cp .env.local.example .env.local

# 로컬 백엔드 주소 (프록시(rewrites)를 못 타는 요청에 사용, 브라우저에 노출됨)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# next.config.mjs의 /api rewrites 목적지 (서버 전용, 브라우저에 노출 안 됨)
BACKEND_URL=http://localhost:8080

# 네이버페이 JS SDK 초기화용(clientSecret 아님, 브라우저에 노출되는 게 정상)
NEXT_PUBLIC_NAVERPAY_CLIENT_ID=
NEXT_PUBLIC_NAVERPAY_CHAIN_ID=
